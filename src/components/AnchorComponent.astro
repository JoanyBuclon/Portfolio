<script>
  function toggleAnchor(): void {
    const anchor = document.querySelector<HTMLElement>('.anchor');
    if (!anchor) return;
    if (window.scrollY > 150) {
      anchor.classList.remove('is-hidden');
    } else {
      anchor.classList.add('is-hidden');
    }
  }

  function onAnchorClick(e: MouseEvent): void {
    const target = e.target as Element | null;
    if (target?.closest('.anchor')) {
      document.body.scrollIntoView();
    }
  }

  window.addEventListener('scroll', toggleAnchor);
  document.addEventListener('click', onAnchorClick);
  document.addEventListener('astro:page-load', toggleAnchor);
  toggleAnchor();
</script>

<button class='anchor is-hidden'>
  <div class='line one'></div>
  <div class='line two'></div>
  <span class='text-xs'>BACK TO TOP</span>
</button>

<style>
  .anchor {
    background: none;
    border: none;
    opacity: 1;
    transition:
      opacity 0.5s,
      visibility 0.5s;
    z-index: 20;
    position: fixed;
    cursor: pointer;
    bottom: 220px;
    right: 20px;
    color: white;
  }

  .anchor span {
    writing-mode: vertical-rl;
  }

  .line {
    margin: auto;
    display: block;
    background-color: white;
    width: 2px;
    margin-bottom: 20px;
  }

  .one {
    height: 200px;
  }

  .two {
    height: 120px;
  }

  .is-hidden {
    opacity: 0;
    visibility: hidden;
  }

  .anchor:hover span {
    color: oklch(70.2% 0.183 293.541);
  }

  .anchor:hover .line {
    background-color: oklch(70.2% 0.183 293.541);
  }

  @media screen and (max-width: 600px) {
    .anchor {
      bottom: 90px;
      right: 4px;
    }

    .anchor span {
      font-size: 0.7em;
    }
  }
</style>
