---
import { internships, works } from '../data/timeline';
---

<div class='timeline mode-work'>
  <div class='mobile-toggle'>
    <button
      type='button'
      data-mode='internship'
      class='border-2 border-emerald-400 text-emerald-400 px-4 py-2 rounded-full cursor-pointer'>education</button
    >
    <button
      type='button'
      data-mode='work'
      class='border-2 border-blue-400 text-blue-400 px-4 py-2 rounded-full cursor-pointer'>jobs</button
    >
  </div>
  <div class='flex flex-row'>
    <div class='line-edge bg-emerald-400'></div>
    <div class='content internships mode-work cursor-pointer text-emerald-400 hover:text-emerald-300'>
      <div class='main'>
        <h3 class='text-2xl'>education</h3>
        <p>click to expand</p>
      </div>
      <div class='elements'>
        <div class='round border-emerald-400 border-2'></div>
        <div class='line bg-emerald-400'></div>
      </div>
    </div>
    {
      internships.map((ex) => (
        <div class='content mode-internship cursor-pointer text-emerald-400 hover:text-emerald-300' data-id={ex.id}>
          <div class='main'>
            <h3 class='text-2xl'>{ex.title}</h3>
            <p>{ex.subtitle}</p>
          </div>
          <div class='elements'>
            <div class='round border-emerald-400 border-2' />
            <div class='line bg-emerald-400' />
            {ex.year && <span class='year'>{ex.year}</span>}
          </div>
          <div class='inline-description whitespace-pre-line'>
            <p class='inline-when'>{ex.when}</p>
            <p class='inline-desc'>{ex.description}</p>
          </div>
        </div>
      ))
    }
    {
      works.map((ex) => (
        <div class='content mode-work cursor-pointer text-blue-400 hover:text-blue-300' data-id={ex.id}>
          <div class='main'>
            <h3 class='text-2xl'>{ex.title}</h3>
            <p>{ex.subtitle}</p>
          </div>
          <div class='elements'>
            <div class='round bg-blue-400' />
            <div class='line bg-blue-400' />
            {ex.year && <span class='year'>{ex.year}</span>}
          </div>
          <div class='inline-description whitespace-pre-line'>
            <p class='inline-when'>{ex.when}</p>
            <p class='inline-desc'>{ex.description}</p>
          </div>
        </div>
      ))
    }
    <div class='content works mode-internship cursor-pointer text-blue-400 hover:text-blue-300'>
      <div class='main'>
        <h3 class='text-2xl'>jobs</h3>
        <p>click to expand</p>
      </div>
      <div class='elements'>
        <div class='round bg-blue-400'></div>
        <div class='line bg-blue-400'></div>
      </div>
    </div>
  </div>
  <div class='descriptions'>
    <div class='description is-active' data-id='default'>
      <p class='italic'>Click on a timeline item to see details</p>
    </div>
    {
      internships.map((intern) => (
        <div class='description whitespace-pre-line' data-id={intern.id}>
          <h3 class='text-2xl'>{intern.title}</h3>
          <p class='text-lg'>{intern.subtitle}</p>
          <p class='text-lg italic'>from {intern.when}</p>
          <p>{intern.description}</p>
        </div>
      ))
    }
    {
      works.map((work) => (
        <div class='description whitespace-pre-line' data-id={work.id}>
          <h3 class='text-2xl'>{work.title}</h3>
          <p class='text-lg'>{work.subtitle}</p>
          <p class='text-lg italic'>from {work.when}</p>
          <p>{work.description}</p>
        </div>
      ))
    }
  </div>
</div>

<script>
  const TRANSITION_MS = 700;

  type TimelineMode = 'internship' | 'work';

  function attachTimeline(): void {
    const timeline = document.querySelector<HTMLElement>('.timeline');
    if (!timeline) return;

    const internships = document.querySelector<HTMLElement>('.internships');
    const works = document.querySelector<HTMLElement>('.works');

    let isTransitioning = false;
    function lockTransition(): void {
      isTransitioning = true;
      setTimeout(() => {
        isTransitioning = false;
      }, TRANSITION_MS);
    }

    function resetActiveSelection(): void {
      document.querySelectorAll('.content[data-id].is-active').forEach((i) => i.classList.remove('is-active'));
      document.querySelectorAll<HTMLElement>('.description').forEach((d) => {
        d.classList.toggle('is-active', d.dataset.id === 'default');
      });
    }

    function switchMode(targetMode: TimelineMode): void {
      if (isTransitioning) return;
      if (timeline.classList.contains(`mode-${targetMode}`)) return;
      const currentMode: TimelineMode = targetMode === 'work' ? 'internship' : 'work';
      lockTransition();
      resetActiveSelection();
      timeline.classList.replace(`mode-${currentMode}`, `mode-${targetMode}`);
    }

    if (internships) internships.addEventListener('click', () => switchMode('internship'));
    if (works) works.addEventListener('click', () => switchMode('work'));

    document.querySelectorAll<HTMLElement>('.mobile-toggle button').forEach((btn) => {
      btn.addEventListener('click', () => {
        const mode = btn.dataset.mode;
        if (mode === 'work' || mode === 'internship') {
          switchMode(mode);
        }
      });
    });

    function triggerPing(roundEl: Element): void {
      const halo = document.createElement('div');
      halo.className = 'round-halo';
      roundEl.appendChild(halo);
      setTimeout(() => halo.remove(), TRANSITION_MS);
    }

    const items = document.querySelectorAll<HTMLElement>('.content[data-id]');
    const descriptions = document.querySelectorAll<HTMLElement>('.description');

    items.forEach((item) => {
      item.addEventListener('click', () => {
        const id = item.dataset.id;
        descriptions.forEach((d) => {
          d.classList.toggle('is-active', d.dataset.id === id);
        });
        items.forEach((i) => i.classList.toggle('is-active', i === item));
        const round = item.querySelector('.round');
        if (round) triggerPing(round);
      });
    });
  }

  document.addEventListener('astro:page-load', attachTimeline);
</script>

<style>
  .timeline {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 12rem 0 0;
    overflow: visible;
  }
  .content {
    flex: 0 0 auto;
    width: 0;
    min-width: 0;
    pointer-events: none;
    transition: width 0.7s ease-in-out;
  }
  .content .main,
  .content .round {
    opacity: 0;
    transition: opacity 0.2s ease-in-out;
  }
  .content[data-id] .main {
    scale: 0.5;
    transition:
      opacity 0.42s ease-out 0.1s,
      scale 0.42s ease-out 0.1s;
  }
  .content[data-id] .round {
    transition: opacity 0.15s ease-out;
  }

  .timeline.mode-internship .content.mode-work .round,
  .timeline.mode-work .content.mode-internship:not(.works) .round {
    transition: opacity 0s 0.7s;
  }

  .timeline.mode-internship .content.works .main,
  .timeline.mode-work .content.internships .main {
    transition: opacity 0.14s ease-in-out 0.6s;
  }

  .timeline.mode-work .content.works .main,
  .timeline.mode-work .content.works .round,
  .timeline.mode-work .content.works .line {
    opacity: 0;
    transition: opacity 0s;
  }

  @media (prefers-reduced-motion: reduce) {
    .content,
    .content .main,
    .content .round {
      transition: none;
    }
  }

  .round {
    display: block;
    border-radius: 50%;
    width: 15px;
    height: 15px;
    position: relative;
  }

  .content[data-id].is-active .round {
    transform: scale(1.7);
    background: currentColor;
  }

  :global(.round-halo) {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    box-shadow: 0 0 0 2px currentColor;
    pointer-events: none;
    animation: round-ping 0.7s cubic-bezier(0, 0, 0.2, 1) forwards;
  }
  @keyframes round-ping {
    from {
      transform: scale(1);
      opacity: 1;
    }
    to {
      transform: scale(2.5);
      opacity: 0;
    }
  }
  .elements {
    display: flex;
    align-items: center;
    position: relative;
  }

  .year {
    position: absolute;
    top: 100%;
    left: 7.5px;
    transform: translateX(-50%);
    margin-top: 0.5rem;
    color: rgb(209 213 219);
    font-size: 0.75rem;
    white-space: nowrap;
    opacity: 0;
    scale: 0.5;
    transition:
      opacity 0.42s ease-out 0.1s,
      scale 0.42s ease-out 0.1s;
  }
  .timeline.mode-work .mode-work .year,
  .timeline.mode-internship .mode-internship .year {
    opacity: 1;
    scale: 1;
  }
  .descriptions {
    padding-top: 2rem;
    display: grid;
    align-items: center;
    width: 100%;
    max-width: 48rem;
  }

  .line-edge {
    width: 50px;
    height: 2px;
    align-self: flex-end;
    margin-left: 100px;
    margin-bottom: 6.5px;
  }
  .line {
    display: block;
    flex: 1;
    height: 2px;
  }
  .timeline.mode-work .mode-work:not(:has(~ .mode-work)) .line,
  .timeline.mode-internship .mode-internship:not(:has(~ .mode-internship)) .line {
    flex: 0.4;
  }

  .main {
    rotate: -45deg;
    transform-origin: bottom left;
    white-space: nowrap;
    overflow: visible;
    width: 140px;
  }
  .timeline.mode-work .mode-work {
    width: 187px;
    pointer-events: auto;
  }
  .timeline.mode-internship .mode-internship {
    width: 140px;
    pointer-events: auto;
  }
  .timeline.mode-work .mode-work .main,
  .timeline.mode-work .mode-work .round,
  .timeline.mode-internship .mode-internship .main,
  .timeline.mode-internship .mode-internship .round {
    opacity: 1;
    scale: 1;
  }
  .description {
    grid-column: 1;
    grid-row: 1;
    visibility: hidden;
  }
  .description[data-id='default'] {
    text-align: center;
  }
  .description.is-active {
    visibility: visible;
  }

  .mobile-toggle {
    display: none;
  }
  .inline-description {
    display: none;
  }

  @media (max-width: 1023px) {
    .timeline {
      padding: 0;
      min-height: auto;
      overflow: visible;
      align-items: stretch;
    }
    .timeline > .flex-row {
      flex-direction: column;
    }

    .mobile-toggle {
      display: flex;
      gap: 0.75rem;
      justify-content: center;
      margin-bottom: 1.5rem;
    }
    .mobile-toggle button {
      transition:
        background-color 0.2s,
        color 0.2s;
    }
    .timeline.mode-internship .mobile-toggle button[data-mode='internship'] {
      background-color: rgb(52 211 153);
      color: rgb(0 0 0);
    }
    .timeline.mode-work .mobile-toggle button[data-mode='work'] {
      background-color: rgb(96 165 250);
      color: rgb(0 0 0);
    }

    .line-edge {
      display: none;
    }
    .content.internships,
    .content.works {
      display: none !important;
    }
    .timeline.mode-work .content[data-id].mode-internship,
    .timeline.mode-internship .content[data-id].mode-work {
      display: none;
    }

    .content {
      width: 100%;
      pointer-events: auto;
      transition: none;
      position: relative;
      display: grid;
      grid-template-columns: 1.5rem 1fr;
      grid-template-areas:
        'marker label'
        'marker desc';
      grid-auto-rows: min-content;
      column-gap: 1rem;
      padding: 0.25rem 0;
      align-items: start;
    }
    .timeline.mode-work .content[data-id].mode-work,
    .timeline.mode-internship .content[data-id].mode-internship {
      width: 100%;
    }

    .content[data-id] .main,
    .content[data-id] .round {
      opacity: 1;
      scale: 1;
      transition: none;
    }

    .elements {
      grid-area: marker;
      flex-direction: column;
      align-items: center;
      align-self: stretch;
      height: 100%;
      position: static;
    }
    .line {
      width: 2px;
      height: auto;
      flex: 1;
      min-height: 1.5rem;
    }
    .timeline.mode-work .content.mode-work[data-id]:last-of-type .line,
    .timeline.mode-internship .content.mode-internship[data-id]:last-of-type .line {
      display: none;
    }

    .main {
      grid-area: label;
      rotate: 0deg;
      transform-origin: 0 0;
      width: auto;
      white-space: normal;
      overflow: visible;
      padding-right: 2.5rem;
    }
    .main h3 {
      font-size: 1.05rem;
      line-height: 1.3;
    }
    .main p {
      font-size: 0.85rem;
    }

    .year {
      position: absolute;
      top: 0.25rem;
      right: 0;
      left: auto;
      margin-top: 0;
      transform: none;
      opacity: 1;
      scale: 1;
      transition: none;
    }

    .inline-description {
      grid-area: desc;
      display: none;
      margin-top: 0.5rem;
      padding-bottom: 0.5rem;
      color: rgb(229 231 235);
      font-size: 0.9rem;
    }
    .content[data-id].is-active .inline-description {
      display: block;
    }

    .descriptions {
      display: none;
    }
  }
</style>
