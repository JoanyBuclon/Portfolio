---
import '../styles/global.css';
import { Font } from 'astro:assets';
import { ClientRouter } from 'astro:transitions';
import HeaderComponent from '../components/HeaderComponent.astro';
import AnchorComponent from '../components/AnchorComponent.astro';
import PageTransition from '../components/PageTransition.astro';
import CloudBackground from '../components/CloudBackground.astro';
import RainBackground from '../components/RainBackground.astro';
const { title, description = "Hi, I'm Joany Buclon, welcome to my portfolio." } = Astro.props;
const ogImage = 'https://joanybuclon.com/og-cover.jpg';
---

<html lang='en'>
  <head>
    <meta charset='utf-8' />
    <title>{title}</title>
    <meta name='description' content={description} />
    <meta name='viewport' content='width=device-width, initial-scale=1' />
    <meta name='generator' content={Astro.generator} />

    <meta property='og:type' content='website' />
    <meta property='og:title' content={title} />
    <meta property='og:description' content={description} />
    <meta property='og:image' content={ogImage} />
    <meta property='og:url' content={Astro.url.href} />
    <meta property='og:locale' content='en_US' />

    <meta name='twitter:card' content='summary_large_image' />
    <meta name='twitter:title' content={title} />
    <meta name='twitter:description' content={description} />
    <meta name='twitter:image' content={ogImage} />

    <link rel='icon' type='image/svg+xml' href='/favicon.svg' />
    <link rel='icon' href='/favicon.ico' />
    <Font cssVariable='--font-migra' preload />
    <Font cssVariable='--font-neue-montreal' preload />
    <ClientRouter />
    <script
      type='application/ld+json'
      set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'Person',
        name: 'Joany Buclon',
        jobTitle: 'Tech Lead Engineer',
        url: 'https://joanybuclon.com',
        email: 'contact@joanybuclon.com',
        description: 'Tech Lead Engineer and Novelist based in Bordeaux, France.',
        sameAs: ['https://github.com/JoanyBuclon', 'https://linkedin.com/in/joany-buclon/'],
      })}
    />
    <script is:inline>
      window.__weather = localStorage.getItem('weather') || 'off';
      if (window.__weather === 'storm') document.documentElement.classList.add('storm');
      if (window.__weather === 'snow') document.documentElement.classList.add('snow');
    </script>
  </head>
  <body class='bg-neutral-950 text-white min-h-screen flex flex-col'>
    <CloudBackground />
    <RainBackground />

    <PageTransition />

    <HeaderComponent />
    <AnchorComponent />

    <main class='flex flex-1 items-center justify-center'>
      <slot />
    </main>
  </body>
</html>

<style is:global>
  /* Custom Scrollbar */
  html {
    scrollbar-color: white transparent;
    scrollbar-width: thin;
  }

  html::-webkit-scrollbar {
    width: 7px;
  }

  html::-webkit-scrollbar-thumb {
    background: white;
    border-radius: 17px;
  }

  html::-webkit-scrollbar-thumb:hover {
    background: white;
  }
</style>
