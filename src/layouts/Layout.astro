---
import '../styles/global.css';
import HeaderComponent from '../components/HeaderComponent.astro';
import AnchorComponent from '../components/AnchorComponent.astro';
import BetaComponent from '../components/BetaComponent.astro';
const { title } = Astro.props;
---

<html lang='en'>
  <head>
    <meta charset='utf-8' />
    <meta
      name='description'
      content="Hi, I'm Joany Buclon, a french Novelist and Software Engineer. Welcome to my portfolio."
    />

    <link rel='icon' type='image/svg+xml' href='/favicon.svg' />
    <link rel='icon' href='/favicon.ico' />
    <meta name='viewport' content='width=device-width, initial-scale=1' />
    <meta name='generator' content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class='bg-neutral-950 text-white min-h-screen flex flex-col'>
    <!-- THIS IS A TEMPORARY COMPONENT -->
    <BetaComponent />

    <HeaderComponent />
    <AnchorComponent />
    <main class='flex flex-1 items-center justify-center'>
      <slot />
    </main>
  </body>
</html>

<style is:global>
  /* Custom Scrollbar */
  html {
    scrollbar-color: white transparent;
    scrollbar-width: thin;
  }

  html::-webkit-scrollbar {
    width: 7px;
  }

  html::-webkit-scrollbar-thumb {
    background: white;
    border-radius: 17px;
  }

  html::-webkit-scrollbar-thumb:hover {
    background: white;
  }
</style>
