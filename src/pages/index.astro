---
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import cloudImage from '../assets/cloud.png';
---

<Layout title='Joany Buclon'>
  <section class='hero relative w-full min-h-screen overflow-hidden grid place-items-center'>
    <Image
      src={cloudImage}
      alt=''
      class='col-start-1 row-start-1 w-[90vw] md:w-[65vw] max-w-275 h-auto md:translate-x-[17%] brightness-[0.85] pointer-events-none'
      widths={[600, 900, 1200]}
      sizes='(max-width: 768px) 80vw, 55vw'
      format='webp'
      quality={90}
      loading='eager'
    />
    <div
      class='hero-text col-start-1 row-start-1 relative z-10 flex flex-col gap-4 p-6 md:p-10 md:-translate-x-[15%] translate-y-25'
    >
      <h1 class='text-6xl sm:text-7xl md:text-8xl lg:text-9xl font-display'>Joany Buclon</h1>
      <h2 class='text-xl md:text-2xl'>Novelist & Software Engineer</h2>
    </div>
  </section>
</Layout>

<style>
  .hero-text {
    text-shadow: 0 2px 12px rgba(0, 0, 0, 0.7);
  }
</style>
