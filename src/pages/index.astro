---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Joany Buclon"
  description="Hi, I'm Joany Buclon, a french Novelist and Software Engineer. Welcome to my portfolio."
>
  <div class="flex flex-col gap-4 p-6 md:p-10 overflow-visible">
    <h1 class="text-6xl sm:text-7xl md:text-8xl lg:text-9xl font-display">Joany Buclon</h1>
    <h2 class="text-xl md:text-2xl">Novelist & Software Engineer</h2>
  </div>
</Layout>

<script>
  function setup(): void {
    const h1 = document.querySelector<HTMLHeadingElement>('h1');
    if (!h1) return;
    h1.style.touchAction = 'manipulation';
    let n = 0;
    let t: ReturnType<typeof setTimeout>;
    h1.addEventListener('pointerdown', () => {
      clearTimeout(t);
      n++;
      t = setTimeout(() => {
        n = 0;
      }, 400);
      if (n >= 5) {
        n = 0;
        const current = ((window as any).__weather as string) || 'off';
        const isDecember = new Date().getMonth() === 11;
        const snowChance = isDecember ? 0.9 : 0.1;
        const newMode = current !== 'off' ? 'off' : Math.random() < snowChance ? 'snow' : 'storm';
        (window as any).__weather = newMode;
        if (newMode === 'off') {
          localStorage.removeItem('weather');
        } else {
          localStorage.setItem('weather', newMode);
        }
        document.documentElement.classList.toggle('storm', newMode === 'storm');
        document.documentElement.classList.toggle('snow', newMode === 'snow');
        setTimeout(() => {
          document.dispatchEvent(new CustomEvent('weather:change', { detail: { mode: newMode } }));
        }, 0);
      }
    });
  }
  document.addEventListener('astro:page-load', setup);
</script>
