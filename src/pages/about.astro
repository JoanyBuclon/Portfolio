---
import Layout from '../layouts/Layout.astro';
import ScrollArrowComponent from '../components/ScrollArrowComponent.astro';
import TimelineComponent from '../components/TimelineComponent.astro';
import SkillCardComponent from '../components/SkillCardComponent.astro';
---

<Layout title='About - Joany Buclon'>
  <div>
    <div class='relative flex flex-col justify-center min-h-screen items-center p-10 pt-0'>
      <h1 class='text-8xl'>About Me</h1>
      <ScrollArrowComponent />
    </div>
    <div class='max-w-9/10 mx-auto px-6'>
      <div class='flex flex-col p-10 gap-2'>
        <p>
          Hello <span class='font-semibold'>Beta Readers</span>! The following content comes directly from the current
          portfolio over at <a class='text-violet-400 hover:text-violet-300' href='https://joanybuclon.com'
            >the main url</a
          >! It will be updated as we get closer to the final version.
        </p>
        <p>
          Hi, my name is Joany! I convert coffee, music and books into code for humans and machines alike. I currently
          live near Bordeaux, France. I work 4/5ths for Sfeir Bordeaux as a backend-developer.
        </p>
        <p>
          I spend my free time on various hobbies that inspire my personal projects. Curious and quiet, learning new
          things fuels my creativity. I love spending time with my friends. I’m also a fan of movies, literature and
          gaming.
        </p>
        <p>Don’t hesitate to read more about me and my projects!</p>
      </div>
      <div class='flex flex-col p-10 gap-8'>
        <h2 class='text-5xl'>Experience</h2>
        <TimelineComponent />
      </div>
      <div class='flex flex-col p-10 gap-8'>
        <h2 class='text-5xl'>Profile</h2>
        <SkillCardComponent />
      </div>
      <div class='flex flex-col p-10 gap-8 m-30'>
        <h2 class='text-xl text-center'>
          <a href='mailto: joany.buclon@viacesi.fr'>joany.buclon@viacesi.fr</a>
        </h2>
      </div>
    </div>
  </div>
</Layout>
